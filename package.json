{
  "name": "holes",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"vite\" \"wrangler dev --port 8787\"",
    "dev:worker": "wrangler dev --port 8787",
    "dev:ui": "vite",
    "build": "vite build",
    "build:check": "tsc --noEmit",
    "deploy": "npm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "migrate:local": "wrangler d1 migrations apply DB --local",
    "migrate:remote": "wrangler d1 migrations apply DB --remote",
    "preview": "vite preview"
  },
  "dependencies": {
    "marked": "^15.0.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "typescript": "5.9.3",
    "vite": "^6.0.3",
    "wrangler": "4.56.0"
  }
}
